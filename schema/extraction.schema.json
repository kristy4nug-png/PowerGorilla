{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gorilla/ollama-extraction/v1",
  "title": "PowerShell Gorilla Ollama Extraction Record",
  "type": "object",
  "required": ["extractionId", "sourceType", "sourceRef", "extractedAt", "model", "result"],
  "additionalProperties": false,
  "properties": {
    "extractionId": { "type": "string" },
    "sourceType":   {
      "type": "string",
      "enum": ["app-row", "workflow-row", "csv-chunk", "freetext"],
      "description": "Type of source data fed to Ollama"
    },
    "sourceRef":    { "type": "string", "description": "File path, row index, or identifier of the source data" },
    "extractedAt":  { "type": "string", "format": "date-time" },
    "model":        { "type": "string", "description": "Ollama model name used, e.g. llama3.2, mistral-nemo" },
    "prompt":       { "type": "string" },
    "result":       {
      "type": "object",
      "description": "The structured JSON output from Ollama, validated against app or workflow schema"
    },
    "targetSchema": {
      "type": "string",
      "enum": ["gorilla/app/v1", "gorilla/workflow/v1"],
      "description": "Which schema the result was validated against"
    },
    "confidence":   { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0 },
    "schemaValid":  { "type": "boolean", "default": false },
    "validationErrors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Any JSON schema validation errors"
    }
  }
}
